modules = ["nodejs-20", "nix", "web", "python-3.11"]
[agent]
expertMode = true
integrations = ["javascript_gemini_ai_integrations:2.0.0", "javascript_openai_ai_integrations:2.0.0"]

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node -r ./preload.js index.js"
waitForPort = 5000

[[ports]]
localPort = 3001
externalPort = 3001

[[ports]]
localPort = 5000

[deployment]
deploymentTarget = "vm"
run = ["node", "-r", "./preload.js", "index.js"]
